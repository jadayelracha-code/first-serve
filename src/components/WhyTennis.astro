---
const benefits = [
  {
    icon: '💪',
    title: "Exercise that doesn't feel like it",
    body: "You'll forget you're working out. Tennis is a full-body workout disguised as the most fun part of your week.",
  },
  {
    icon: '🤝',
    title: 'The easiest way to meet people',
    body: 'New to Lisbon, or just want to widen your circle? A court is one of the friendliest places to make new friends.',
  },
  {
    icon: '🧠',
    title: 'An hour that clears your head',
    body: 'Phone down, sun out, fully present. Tennis is brilliant for switching off the noise and lifting your mood.',
  },
  {
    icon: '🎾',
    title: "A sport you'll keep for life",
    body: 'Start now and play for decades. Tennis is one of the few sports you simply never age out of.',
  },
];

// Facebook Reel embed (canonical URL resolved from the share link).
const fbReelUrl = 'https://www.facebook.com/reel/4390594114589350/';
const fbEmbed = `https://www.facebook.com/plugins/video.php?href=${encodeURIComponent(
  fbReelUrl
)}&show_text=false&width=320&height=569`;

// Instagram Reel embed.
const igReelUrl = 'https://www.instagram.com/reel/CqyDRPAPr4N/';
const igEmbed = 'https://www.instagram.com/reel/CqyDRPAPr4N/embed';

// Research sources backing the health claims above.
const sources = [
  { label: 'Harvard Health', url: 'https://www.health.harvard.edu/blog/racket-sports-serve-up-health-benefits-2017060911780' },
  { label: 'PubMed study', url: 'https://pubmed.ncbi.nlm.nih.gov/39129051/' },
  { label: 'Medium', url: 'https://medium.com/in-fitness-and-in-health/the-real-reasons-racket-sports-add-9-years-to-your-life-dea4325f0db2' },
];
---

<section class="reveal bg-surface/60" data-dust>
  <div class="mx-auto max-w-content px-5 sm:px-8 py-20 md:py-28">
    <div class="text-center max-w-2xl mx-auto">
      <p class="font-body text-xs font-semibold tracking-widest uppercase text-clay mb-4">
        More than a sport
      </p>
      <h2 class="font-display text-3xl md:text-4xl font-medium text-text">
        Why learn tennis? ☀️
      </h2>
      <p class="mt-4 font-body text-base md:text-lg text-text-muted leading-relaxed">
        It's not just about the game. Picking up a racket gives you back a few
        things modern life keeps taking away.
      </p>
    </div>

    <div class="stagger mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        benefits.map((b) => (
          <div class="card-lift bg-surface border border-line rounded-2xl p-7">
            <span
              class="flex h-12 w-12 items-center justify-center rounded-full bg-sun/25 text-2xl mb-5"
              aria-hidden="true"
            >
              {b.icon}
            </span>
            <h3 class="font-display text-lg font-medium text-text mb-2">{b.title}</h3>
            <p class="font-body text-sm text-text-muted leading-relaxed">{b.body}</p>
          </div>
        ))
      }
    </div>

    <!-- Credibility: the research backs it up -->
    <div class="mt-12 max-w-3xl mx-auto rounded-2xl bg-court/5 border border-court/15 p-6 md:p-7 text-center">
      <p class="font-body text-base text-text leading-relaxed">
        💚 And it's not just us saying it — research links racket sports to a
        longer life, a healthier heart, and a sharper mind. Some studies even
        associate them with up to <strong class="text-court-deep">~9 extra years</strong> of life.
      </p>
      <p class="mt-3 font-body text-sm text-text-muted">
        Sources:{' '}
        {
          sources.map((s, i) => (
            <>
              {i > 0 && <span aria-hidden="true"> · </span>}
              <a href={s.url} target="_blank" rel="noopener" class="text-court-deep font-medium hover:underline underline-offset-4">
                {s.label}
              </a>
            </>
          ))
        }
      </p>
    </div>

    <!-- Reels: a little taste of court time -->
    <div class="mt-14">
      <p class="text-center font-body text-sm font-semibold tracking-wide text-text-muted mb-6">
        🎾 A little taste of court time
      </p>
      <div class="grid gap-6 sm:grid-cols-2 max-w-2xl mx-auto items-start">
        <!-- Facebook reel -->
        <div class="text-center">
          <div class="relative overflow-hidden rounded-2xl border border-line shadow-sm bg-court/10 aspect-[9/16]">
            <iframe
              src={fbEmbed}
              title="Tennis reel on Facebook"
              class="absolute inset-0 h-full w-full"
              style="border:none;overflow:hidden"
              scrolling="no"
              frameborder="0"
              loading="lazy"
              allowfullscreen
              allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
            ></iframe>
          </div>
          <a href={fbReelUrl} target="_blank" rel="noopener" class="mt-3 inline-block font-body text-sm text-court-deep font-medium hover:underline underline-offset-4">
            Watch on Facebook ↗
          </a>
        </div>
        <!-- Instagram reel -->
        <div class="text-center">
          <div class="relative overflow-hidden rounded-2xl border border-line shadow-sm bg-court/10 aspect-[9/16]">
            <iframe
              src={igEmbed}
              title="Tennis reel on Instagram"
              class="absolute inset-0 h-full w-full"
              style="border:none;overflow:hidden"
              scrolling="no"
              frameborder="0"
              loading="lazy"
              allowfullscreen
              allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
            ></iframe>
          </div>
          <a href={igReelUrl} target="_blank" rel="noopener" class="mt-3 inline-block font-body text-sm text-court-deep font-medium hover:underline underline-offset-4">
            Watch on Instagram ↗
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
