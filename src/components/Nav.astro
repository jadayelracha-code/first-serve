---
import Wordmark from './Wordmark.astro';
import { waLink } from '../config';
const wa = waLink();
---

<header
  id="site-nav"
  class="fixed top-0 inset-x-0 z-30 transition-colors duration-300"
>
  <nav class="mx-auto max-w-content px-5 sm:px-8 h-16 flex items-center justify-between">
    <a href="#top" class="text-xl" aria-label="First Serve — home">
      <Wordmark />
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-7 font-body text-sm">
      <a href="#how-it-works" class="text-text-muted hover:text-court-deep transition-colors">How it works</a>
      <a href="#pricing" class="text-text-muted hover:text-court-deep transition-colors">Pricing</a>
      <a href="#about" class="text-text-muted hover:text-court-deep transition-colors">About</a>
      <a
        href={wa}
        target="_blank"
        rel="noopener"
        class="btn-clay text-white font-semibold rounded-full px-5 py-2.5 text-sm shadow-sm"
      >
        Reserve a spot
      </a>
    </div>
  </nav>
</header>

<!-- Mobile persistent WhatsApp button (appears after 2s, gentle pulse) -->
<a
  id="mobile-wa"
  href={wa}
  target="_blank"
  rel="noopener"
  class="md:hidden fixed bottom-5 right-5 z-40 btn-clay text-white font-semibold rounded-full px-5 py-3.5 text-sm shadow-lg opacity-0 pointer-events-none flex items-center gap-2"
  aria-label="Reserve a spot on WhatsApp"
>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12 2a10 10 0 0 0-8.6 15.05L2 22l5.1-1.34A10 10 0 1 0 12 2Zm5.5 14.2c-.23.65-1.35 1.24-1.86 1.28-.5.05-.97.23-3.26-.68-2.76-1.09-4.5-3.93-4.64-4.11-.13-.18-1.1-1.46-1.1-2.79 0-1.32.7-1.97.94-2.24.24-.27.52-.34.7-.34l.5.01c.16 0 .38-.06.59.45.23.55.77 1.9.84 2.04.07.13.11.29.02.47-.09.18-.13.29-.27.45l-.4.46c-.13.13-.27.28-.12.54.16.27.7 1.15 1.5 1.86 1.04.92 1.9 1.2 2.17 1.34.27.13.42.11.58-.07.16-.18.67-.78.85-1.05.18-.27.36-.22.6-.13.25.09 1.6.75 1.87.89.27.13.45.2.52.31.07.11.07.65-.16 1.3Z"/>
  </svg>
  Reserve a spot
</a>

<script>
  // Nav: transparent → frosted after 60px scroll
  const nav = document.getElementById('site-nav');
  function onNavScroll() {
    if (!nav) return;
    if (window.scrollY > 60) {
      nav.classList.add('bg-bg/90', 'backdrop-blur', 'shadow-sm');
    } else {
      nav.classList.remove('bg-bg/90', 'backdrop-blur', 'shadow-sm');
    }
  }
  window.addEventListener('scroll', onNavScroll, { passive: true });
  onNavScroll();

  // Mobile WhatsApp button: reveal after 2s
  const mobileWa = document.getElementById('mobile-wa');
  if (mobileWa) {
    window.setTimeout(() => {
      mobileWa.classList.remove('opacity-0', 'pointer-events-none');
      mobileWa.classList.add('float-cta', 'pointer-events-auto');
    }, 2000);
  }
</script>
