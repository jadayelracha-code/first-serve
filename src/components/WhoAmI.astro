---
// If Rasha has a photo on a court, drop it in /public and set photoSrc.
// Otherwise a warm court-green gradient block shows, clearly marked.
const photoSrc = ''; // ⚠️ e.g. '/rasha-court.webp' — leave '' for placeholder
---

<section id="about" class="reveal scroll-mt-20">
  <div class="mx-auto max-w-content px-5 sm:px-8 py-20 md:py-28">
    <div class="grid gap-10 md:gap-14 md:grid-cols-2 items-center">
      <!-- Photo / placeholder -->
      <div class="order-1">
        {
          photoSrc ? (
            <img
              src={photoSrc}
              alt="Rasha on a tennis court in the Almada area"
              width="640"
              height="720"
              loading="lazy"
              class="w-full rounded-2xl object-cover aspect-[4/5]"
            />
          ) : (
            <div
              class="w-full rounded-2xl aspect-[4/5] flex flex-col items-center justify-center gap-6 text-center p-8"
              style="background: linear-gradient(150deg, #5B8C5A, #3E6B3D);"
            >
              <span class="tennis-ball" style="width:5rem;height:5rem;" aria-hidden="true"></span>
              <span class="font-display text-2xl md:text-3xl text-white font-medium">
                See you on the court 🎾
              </span>
            </div>
          )
        }
      </div>

      <!-- Text -->
      <div class="order-2">
        <p class="font-body text-xs font-semibold tracking-widest uppercase text-clay mb-4">
          Hi, I'm Rasha
        </p>
        <h2 class="font-display text-3xl md:text-4xl font-medium text-text leading-tight">
          I'm learning to coach — and I haven't forgotten how it feels to start.
        </h2>
        <div class="mt-6 space-y-4 font-body text-base md:text-lg leading-relaxed text-text-muted">
          <p>
            I'm training to coach through the Portuguese Tennis Federation — I've
            completed the theory, and I'm now finishing my official coaching
            internship. So this is the real thing, not a weekend hobby. And
            honestly, being early in my coaching journey might be the best part:
            I remember exactly what it's like to stand on a court not knowing
            what to do with your hands. I know the nerves. I know the
            self-consciousness. And I know how good it feels when that first ball
            finally lands where you wanted it.
          </p>
          <p>
            That's the whole reason I started this — to give beginners the
            patient, no-judgment start I wish everyone got.
          </p>
        </div>

        <!-- Personal touch -->
        <p class="mt-6 inline-flex items-center gap-2.5 rounded-full bg-sun/25 border border-sun/50 px-4 py-2 font-body text-sm md:text-base font-medium text-text">
          <span class="tennis-ball ball-bullet" aria-hidden="true"></span>
          My favorite shot is a double-handed backhand — and I can fix yours. 🎾
        </p>
      </div>
    </div>
  </div>
</section>
