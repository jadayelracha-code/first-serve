---
import { waLink } from '../config';
const wa = waLink('Hi Rasha! I\'d love to be one of your first First Serve players.');
---

{/*
  ⚠️ PLACEHOLDER — replace with real testimonials before launch.
  Do NOT publish invented quotes.
  When you have 2–3 real ones, swap the placeholder card below,
  or comment this whole <section> out until then.
*/}
<section class="reveal">
  <div class="mx-auto max-w-content px-5 sm:px-8 py-20 md:py-28">
    <div class="text-center max-w-2xl mx-auto">
      <p class="font-body text-xs font-semibold tracking-widest uppercase text-clay mb-4">
        Coming soon
      </p>
      <h2 class="font-display text-3xl md:text-4xl font-medium text-text">
        First players, first words.
      </h2>
    </div>

    <div class="mt-12 max-w-xl mx-auto">
      <figure class="bg-surface border border-dashed border-line rounded-2xl p-8 md:p-10 text-center">
        <span class="tennis-ball ball-bullet mx-auto mb-5" aria-hidden="true"></span>
        <blockquote class="font-display text-xl md:text-2xl font-medium text-text leading-snug">
          “Real beginner stories will live here once the first summer group
          wraps. Want to be one of them?”
        </blockquote>
        <a
          href={wa}
          target="_blank"
          rel="noopener"
          class="mt-6 inline-block font-body text-court-deep font-semibold hover:underline underline-offset-4"
        >
          Be one of the first →
        </a>
      </figure>
    </div>
  </div>
</section>
